#include <iostream>
#include <cstring>
using namespace std;

class Employee
{
private:
    char *name;
    double salary;

public:
    Employee(const char *n, double s)
    {
        name = new char[strlen(n) + 1];
        strcpy(name, n);
        salary = s;

        cout << "Constructor Called" << endl;
    }

    void display()
    {
        cout << "Name: " << name
             << "\nSalary: " << salary << endl;
    }

    ~Employee()
    {
        delete[] name;
        cout << "Destructor Called" << endl;
    }
};

int main()
{
    Employee e1("John", 50000);

    e1.display();

    return 0;
}
