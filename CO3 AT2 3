#include <iostream>
using namespace std;

class Distance
{
private:
    int meters;
    int centimeters;

public:
    Distance(int m = 0, int c = 0)
    {
        meters = m;
        centimeters = c;
    }

    Distance operator+(Distance d)
    {
        Distance temp;

        temp.meters = meters + d.meters;
        temp.centimeters = centimeters + d.centimeters;

        if (temp.centimeters >= 100)
        {
            temp.meters += temp.centimeters / 100;
            temp.centimeters %= 100;
        }

        return temp;
    }

    void display()
    {
        cout << meters << " meters "
             << centimeters << " centimeters" << endl;
    }
};

