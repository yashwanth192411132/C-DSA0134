#include <iostream>
#include <cstring>
using namespace std;

class Student
{
private:
    char *name;
    int marks;

public:
    Student(const char *n, int m)
    {
        name = new char[strlen(n) + 1];
        strcpy(name, n);
        marks = m;
    }

    Student(const Student &s)
    {
        name = new char[strlen(s.name) + 1];
        strcpy(name, s.name);
        marks = s.marks;
    }

    void modify(const char *n, int m)
    {
        delete[] name;
        name = new char[strlen(n) + 1];
        strcpy(name, n);
        marks = m;
    }

    void display()
    {
        cout << "Name: " << name
             << "\tMarks: " << marks << endl;
    }

    ~Student()
    {
        delete[] name;
    }
};

int main()
{
    Student s1("John", 85);

    Student s2 = s1;

    s2.modify("David", 95);

    cout << "Original Object:\n";
    s1.display();

    cout << "Copied Object:\n";
    s2.display();

    return 0;
}
