#include <iostream>
using namespace std;

class Box
{
private:
    double volume;

public:
    Box(double v)
    {
        volume = v;
    }

    bool operator>(Box b)
    {
        return volume > b.volume;
    }

    void display()
    {
        cout << "Volume = " << volume << endl;
    }
};

int main()
{
    Box b1(150.5);
    Box b2(200.8);

    b1.display();
    b2.display();

    if (b1 > b2)
        cout << "Box 1 has greater volume" << endl;
    else
        cout << "Box 2 has greater volume" << endl;

    return 0;
}
